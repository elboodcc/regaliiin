<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>¡Un Regalo para Ti!</title>
    <style>
        /* Pantalla completamente blanca y centrada */
        body {
            margin: 0;
            padding: 0;
            background-color: #ffffff;
            font-family: 'Arial', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        /* Contenedor principal */
        .contenedor {
            text-align: center;
        }

        /* Estilos del botón morado */
        .btn-regalo {
            background-color: #7B2CBF;
            color: #ffffff;
            font-size: 22px;
            font-weight: bold;
            padding: 15px 35px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(123, 44, 191, 0.4);
            transition: transform 0.2s, background-color 0.2s;
        }

        /* Efecto al pasar el mouse por encima */
        .btn-regalo:hover {
            background-color: #9D4EDD;
            transform: scale(1.05);
        }

        /* Efecto al hundir el botón */
        .btn-regalo:active {
            transform: scale(0.95);
        }

        /* Estilos de la imagen sorpresa (oculta al inicio) */
        .imagen-sorpresa {
            display: none;
            max-width: 90%;
            max-height: 80vh;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            animation: aparecer 0.8s ease forwards;
        }

        /* Animación para que aparezca suavemente */
        @keyframes aparecer {
            from {
                opacity: 0;
                transform: scale(0.8);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
</head>
<body>

    <div class="contenedor">
        <button class="btn-regalo" id="botonRegalo">¡Presiona aquí para tu regalo!</button>

        <img src="imgs/imgs/jajaxdbvromaaa.jpg" alt="Regalo Sorpresa" class="imagen-sorpresa" id="imagenRegalo">
    </div>

    <script>
        // Función para cambiar el botón por la imagen al hacer clic
        document.getElementById('botonRegalo').addEventListener('click', function() {
            // Esconde el botón morado
            this.style.display = 'none';
            
            // Muestra la imagen sorpresa
            const imagen = document.getElementById('imagenRegalo');
            imagen.style.display = 'block';
        });
    </script>

</body>
</html>

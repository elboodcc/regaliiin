<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>parra mira tu regalo brouu </title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        /* BASE Y FONDO */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            background: radial-gradient(circle at top, #1a0f0f 0%, #050608 45%, #020203 100%);
            font-family: 'Roboto', sans-serif; 
            color: #fff; 
            overflow-x: hidden;
        }

        /* NAVEGACIÓN */
        nav { 
            background: rgba(10, 5, 5, 0.98); 
            padding: 20px 30px; 
            display: flex; 
            justify-content: center; 
            border-bottom: 3px solid #ff3939;
            box-shadow: 0 5px 25px rgba(255, 0, 0, 0.3);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        nav .logo { color: #ff3939; font-size: 35px; font-weight: 900; text-transform: uppercase; letter-spacing: 4px; text-shadow: 0 0 15px rgba(255, 0, 0, 0.5); }

        /* BUSCADOR Y CONTADOR */
        .header-tools {
            max-width: 1200px;
            margin: 40px auto 10px;
            padding: 0 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }
        #gameSearch {
            width: 100%;
            max-width: 600px;
            padding: 15px 25px;
            border-radius: 8px;
            border: 1px solid #333;
            background: #111;
            color: white;
            outline: none;
            font-size: 16px;
            text-align: center;
            transition: 0.3s;
        }
        #gameSearch:focus { border-color: #ff3939; box-shadow: 0 0 15px rgba(255, 57, 57, 0.2); }
        .counter-badge { color: #ff5b5b; font-size: 14px; font-weight: bold; text-transform: uppercase; opacity: 0.8; }

        /* GRILLA DE JUEGOS */
        .container { 
            padding: 40px 20px; 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
            gap: 25px; 
            max-width: 1300px;
            margin: 0 auto;
        }

        .game-card { 
            background: #0f0f0f; 
            border-radius: 8px; 
            overflow: hidden; 
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            cursor: pointer;
            border: 1px solid #222;
            position: relative;
        }

        .game-card:hover { 
            transform: scale(1.06); 
            box-shadow: 0 0 30px rgba(255, 0, 0, 0.4);
            border-color: #ff3939;
            z-index: 10;
        }

        .game-thumb { width: 100%; height: 300px; overflow: hidden; position: relative; }
        .game-thumb img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
        .game-info { padding: 15px; background: #0a0a0a; text-align: center; border-top: 2px solid #ff3939; }
        .game-title { font-size: 14px; color: #fff; font-weight: 700; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; letter-spacing: 0.5px; }
        .game-req-data { display: none; }

        /* ESTILO DE PAGINACIÓN */
        .pagination {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin: 20px 0 40px;
        }
        .page-btn {
            background: #111;
            border: 1px solid #333;
            color: #fff;
            padding: 10px 20px;
            cursor: pointer;
            border-radius: 5px;
            font-weight: bold;
            transition: 0.3s;
        }
        .page-btn:hover { border-color: #ff3939; color: #ff3939; }
        .page-btn.active { background: #ff3939; border-color: #ff3939; }

        /* MODAL */
        .modal-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.95);
            backdrop-filter: blur(10px);
            display: none; align-items: center; justify-content: center;
            z-index: 2000; padding: 20px;
        }
        .modal {
            width: 100%; max-width: 900px;
            background: #0d0d0d;
            border-radius: 15px; border: 1px solid #ff393950;
            position: relative; overflow: hidden;
            display: flex; flex-wrap: wrap;
            box-shadow: 0 0 50px rgba(255, 0, 0, 0.2);
        }
        .modal-close { position: absolute; top: 15px; right: 20px; font-size: 30px; cursor: pointer; color: #ff3939; z-index: 10; }
        .modal-img-side { flex: 1 1 350px; height: 500px; border-right: 1px solid #333; }
        .modal-img-side img { width: 100%; height: 100%; object-fit: cover; }
        .modal-info-side { flex: 1.2 1 350px; padding: 40px; display: flex; flex-direction: column; background: linear-gradient(135deg, #0d0d0d 0%, #1a0a0a 100%); }
        .modal-stars { color: #ff3939; font-size: 18px; margin-bottom: 10px; }
        .modal-title { font-size: 32px; color: #fff; margin-bottom: 10px; text-transform: uppercase; font-weight: 900; }
        .modal-label { font-size: 12px; color: #ff3939; text-transform: uppercase; font-weight: bold; margin-top: 15px; letter-spacing: 1px; }
        .modal-description { color: #bbb; font-size: 14px; line-height: 1.6; margin-bottom: 10px; }
        .modal-pass-box { background: #221111; padding: 10px; border-radius: 5px; border: 1px dashed #ff3939; color: #ff9999; font-family: monospace; font-size: 15px; margin-bottom: 20px; text-align: center; }
        .modal-req-box { background: rgba(255, 255, 255, 0.03); padding: 15px; border-radius: 8px; border: 1px solid #222; margin-bottom: 25px; color: #ddd; font-size: 13px; }
        .btn-download { display: block; text-align: center; padding: 18px; background: #ff3939; color: #fff; font-weight: bold; border-radius: 5px; text-decoration: none; transition: 0.3s; text-transform: uppercase; letter-spacing: 2px; }
        .btn-download:hover { background: #fff; color: #000; }

        footer { text-align: center; padding: 60px; color: #444; font-size: 11px; text-transform: uppercase; letter-spacing: 2px; }
    </style>
</head>
<body>


<script>
    const searchInput = document.getElementById('gameSearch');
    const cards = Array.from(document.querySelectorAll('.game-card'));
    const paginationContainer = document.getElementById('pagination');
    const overlay = document.getElementById('overlay');
    const itemsPerPage = 30;
    let currentPage = 1;

    function displayPage(page) {
        currentPage = page;
        const start = (page - 1) * itemsPerPage;
        const end = start + itemsPerPage;

        cards.forEach((card, index) => {
            card.style.display = (index >= start && index < end) ? "block" : "none";
        });
        updatePagination();
    }

    function updatePagination() {
        paginationContainer.innerHTML = "";
        const totalPages = Math.ceil(cards.length / itemsPerPage);
        for (let i = 1; i <= totalPages; i++) {
            const btn = document.createElement("button");
            btn.innerText = i;
            btn.className = "page-btn" + (i === currentPage ? " active" : "");
            btn.onclick = () => { displayPage(i); window.scrollTo(0,0); };
            paginationContainer.appendChild(btn);
        }
    }

    searchInput.addEventListener('input', () => {
        const filter = searchInput.value.toLowerCase();
        let count = 0;
        cards.forEach(card => {
            const title = card.querySelector('.game-title').innerText.toLowerCase();
            if(title.includes(filter)) { card.style.display = "block"; count++; }
            else { card.style.display = "none"; }
        });
        if(filter === "") displayPage(1);
        else paginationContainer.innerHTML = "";
        document.getElementById('gameCount').innerText = `${count} JUEGOS DISPONIBLES`;
    });

    cards.forEach(card => {
        card.addEventListener('click', () => {
            document.getElementById('mTitle').innerText = card.querySelector('.game-title').innerText;
            document.getElementById('mImg').src = card.querySelector('img').src;
            document.getElementById('mReq').innerHTML = card.querySelector('.game-req-data').innerHTML;
            document.getElementById('mLink').href = card.getAttribute('data-link');
            document.getElementById('mStars').innerText = card.getAttribute('data-stars') || "★★★★☆";
            document.getElementById('mDesc').innerText = card.getAttribute('data-desc') || "Increíble título para descargar.";
            const pass = card.getAttribute('data-pass');
            const passBox = document.getElementById('mPassContainer');
            if(pass) { passBox.style.display = 'block'; document.getElementById('mPass').innerText = pass; } 
            else { passBox.style.display = 'none'; }
            overlay.style.display = 'flex';
        });
    });

    document.getElementById('closeBtn').onclick = () => overlay.style.display = 'none';
    window.onclick = (e) => { if(e.target == overlay) overlay.style.display = 'none'; }
    
    displayPage(1);
</script>
</body>
</html>
